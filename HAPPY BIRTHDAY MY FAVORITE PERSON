<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Selamat Ulang Tahun! ✨</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-color: #ff758f;
            --secondary-color: #ffb3c1;
            --bg-dark: #0d1b2a;
            --text-light: #f8f9fa;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            scroll-behavior: smooth;
        }

        /* Tombol Musik Utama */
        .music-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
            background: rgba(255, 117, 143, 0.7);
            border: none;
            color: white;
            padding: 10px 15px;
            border-radius: 20px;
            cursor: pointer;
            backdrop-filter: blur(5px);
            font-weight: 600;
            transition: 0.3s;
        }
        .music-btn:hover {
            background: rgba(255, 117, 143, 1);
            transform: scale(1.05);
        }

        /* Navigasi Indikator Slide */
        .slide-nav {
            position: fixed;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 100;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }
        .nav-dot {
            width: 12px;
            height: 12px;
            background: rgba(255, 255, 255, 0.4);
            border-radius: 50%;
            cursor: pointer;
            transition: 0.3s;
        }
        .nav-dot.active {
            background: var(--primary-color);
            transform: scale(1.3);
            box-shadow: 0 0 10px var(--primary-color);
        }

        /* Kontainer Struktur Slide */
        section {
            width: 100vw;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 20px;
            position: relative;
            background-attachment: fixed;
            background-position: center;
            background-size: cover;
        }

        .gallery-title {
            font-family: 'Caveat', cursive;
            font-size: 3.5rem;
            color: var(--secondary-color);
            margin-bottom: 30px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
            text-align: center;
        }

        .gallery-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            width: 100%;
            max-width: 1100px;
            padding: 10px;
        }

        /* Modifikasi layout grid khusus jika item kurang dari 5 agar rapi di desktop */
        @media (min-width: 769px) {
            .gallery-container {
                grid-template-columns: repeat(5, 1fr);
            }
        }

        .photo-card {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            overflow: hidden;
            aspect-ratio: 3/4;
            position: relative;
            cursor: pointer;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        .photo-card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.5s;
        }

        .photo-card:hover {
            transform: translateY(-10px) scale(1.03);
            box-shadow: 0 15px 30px rgba(255, 117, 143, 0.3);
            border-color: var(--primary-color);
        }

        /* --- SLIDE 1: Foto 1 - 5 --- */
        #slide1 {
            background: linear-gradient(135deg, #1a1c29 0%, #2b1025 100%);
        }

        /* --- SLIDE 2: Sweet Seventeen --- */
        #slide2 {
            background: linear-gradient(135deg, #2b1025 0%, #471233 100%);
            text-align: center;
        }

        .neon-text {
            font-size: 4.5rem;
            font-weight: 600;
            color: #fff;
            text-shadow: 
                0 0 7px #fff,
                0 0 10px #fff,
                0 0 21px #fff,
                0 0 42px var(--primary-color),
                0 0 82px var(--primary-color),
                0 0 92px var(--primary-color);
            margin-bottom: 20px;
            font-family: 'Poppins', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .sub-sweet {
            font-family: 'Caveat', cursive;
            font-size: 2.5rem;
            color: var(--secondary-color);
            max-width: 600px;
            line-height: 1.2;
        }

        /* --- SLIDE 3: Doa & Harapan Panjang --- */
        #slide3 {
            background: linear-gradient(135deg, #471233 0%, #31112c 100%);
        }

        .card-wish {
            background: rgba(255, 255, 255, 0.07);
            border-radius: 20px;
            padding: 40px;
            max-width: 750px;
            width: 90%;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            transform: translateY(30px);
            opacity: 0;
            transition: all 1s ease-out;
        }

        #slide3.active-slide .card-wish {
            transform: translateY(0);
            opacity: 1;
        }

        .card-wish p {
            font-size: 1.05rem;
            line-height: 1.8;
            margin-bottom: 20px;
            text-align: justify;
            color: #e0e1dd;
            font-weight: 300;
        }

        .card-wish p:last-child {
            margin-bottom: 0;
            font-weight: 400;
            color: var(--secondary-color);
            text-align: center;
            font-size: 1.15rem;
        }

        /* --- SLIDE 4: Foto 6 - 10 --- */
        #slide4 {
            background: linear-gradient(135deg, #31112c 0%, #1a1c29 100%);
        }

        /* Efek Hiasan Lingkaran/Partikel */
        .particle {
            position: absolute;
            background: radial-gradient(circle, var(--secondary-color) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            opacity: 0.2;
            animation: floatUp 9s infinite linear;
        }

        @keyframes floatUp {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            50% { opacity: 0.3; }
            100% { transform: translateY(-10vh) scale(1); opacity: 0; }
        }

        /* Responsif Smartphone */
        @media (max-width: 768px) {
            .gallery-title { font-size: 2.3rem; }
            .neon-text { font-size: 2.5rem; }
            .sub-sweet { font-size: 1.8rem; }
            .card-wish { padding: 20px; width: 95%; }
            .card-wish p { font-size: 0.95rem; line-height: 1.6; }
            .gallery-container { grid-template-columns: repeat(2, 1fr); gap: 12px; }
            .slide-nav { right: 10px; }
        }
    </style>
</head>
<body>

    <audio id="bgMusic" loop>
        <source src="https://assets.mixkit.co/music/preview/mixkit-ambient-piano-01-2139.mp3" type="audio/mp3">
    </audio>
    <button class="music-btn" onclick="toggleMusic()">🎵 Play Music</button>

    <div class="slide-nav">
        <div class="nav-dot active" onclick="scrollToSlide(1)"></div>
        <div class="nav-dot" onclick="scrollToSlide(2)"></div>
        <div class="nav-dot" onclick="scrollToSlide(3)"></div>
        <div class="nav-dot" onclick="scrollToSlide(4)"></div>
    </div>

    <section id="slide1">
        <h1 class="gallery-title">HAPPY BIRTHDAY ✨</h1>
        <div class="gallery-container">
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.47.jpeg" alt="Foto 1">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.46.jpeg" alt="Foto 2">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.45.jpeg" alt="Foto 3">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.44.jpeg" alt="Foto 4">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.43.jpeg" alt="Foto 5">
            </div>
        </div>
    </section>

    <section id="slide2">
        <h1 class="neon-text">Happy Sweet Seventeen 👑</h1>
        <p class="sub-sweet">Selamat memasuki usia 17 tahun micuu</p>
    </section>

    <section id="slide3">
        <div class="card-wish">
            <p>Selamat ulang tahun ya. Nggak terasa umur hilmi bertambah lagi. Semoga di usia yang baru ini hilmi selalu diberikan kesehatan, kebahagiaan, dan kemudahan dalam setiap langkah yang kamu jalani. Semoga semua hal yang sedang hilmi usahakan bisa berjalan lancar dan satu per satu bisa tercapai sesuai yang hilmi harapkan.</p>
            
            <p>Terima kasih karena sudah menjadi pribadi yang baik dan selalu berusaha memberikan yang terbaik dalam banyak hal. Semoga ke depannya hilmi semakin kuat menghadapi tantangan, semakin bijak dalam mengambil keputusan, dan tetap menjadi diri sendiri yang selama ini dikenal banyak orang.</p>
            
            <p>neja juga berharap hilmi selalu menemukan alasan untuk bersyukur di setiap proses yang dijalani. Semoga tahun ini membawa banyak kesempatan baik, pengalaman baru yang menyenangkan, dan orang-orang yang selalu mendukung yuu.</p>
            
            <p>Sekali lagi, selamat ulang tahun. Semoga hari ini menjadi awal yang baik untuk perjalanan satu tahun ke depan.jangan lupa untuk bahagia. Semoga semua doa baik kembali kepada hilmi.

            ✨❤️I ALWAYS LOVE YOU ✨❤️</p>
        </div>
    </section>

    <section id="slide4">
        <h1 class="gallery-title">❤️LOP LOPP❤️ </h1>
        <div class="gallery-container">
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.42.jpeg" alt="Foto 6">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.41 (1).jpeg" alt="Foto 7">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 18.34.41.jpeg" alt="Foto 8">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 19.50.38.jpeg" alt="Foto 9">
            </div>
            <div class="photo-card">
                <img src="WhatsApp Image 2026-06-16 at 19.48.25.jpeg" alt="Foto 10">
            </div>
        </div>
    </section>

    <canvas id="confettiCanvas" style="position:fixed;top:0;left:0;width:100vw;height:100vh;pointer-events:none;z-index:99;"></canvas>

    <script>
        // Pengaturan Audio / Musik Latar
        const music = document.getElementById('bgMusic');
        const musicBtn = document.querySelector('.music-btn');
        music.volume = 0.5; // Mengatur suara instrumen agar lirih dan syahdu

        function toggleMusic() {
            if (music.paused) {
                music.play().catch(e => console.log("Izin browser diperlukan untuk memutar musik pertama kali."));
                musicBtn.innerHTML = "⏸️ Pause Music";
            } else {
                music.pause();
                musicBtn.innerHTML = "🎵 Play Music";
            }
        }

        // Navigasi Slide Manual saat Dot Diklik
        function scrollToSlide(slideNumber) {
            const target = document.getElementById(`slide${slideNumber}`);
            window.scrollTo({
                top: target.offsetTop,
                behavior: 'smooth'
            });
        }

        // Sinkronisasi Scroll Otomatis dengan Dot Navigasi Samping
        window.addEventListener('scroll', () => {
            const sections = document.querySelectorAll('section');
            const dots = document.querySelectorAll('.nav-dot');
            
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                if (pageYOffset >= sectionTop - 300) {
                    current = section.getAttribute('id');
                    section.classList.add('active-slide');
                } else {
                    section.classList.remove('active-slide');
                }
            });

            dots.forEach((dot, index) => {
                dot.classList.remove('active');
                if (sections[index].getAttribute('id') === current) {
                    dot.classList.add('active');
                }
            });
        });

        // Membuat Hiasan Partikel Mengapung di Setiap Slide
        function createParticles() {
            const sections = document.querySelectorAll('section');
            sections.forEach(section => {
                for (let i = 0; i < 6; i++) {
                    const particle = document.createElement('div');
                    particle.classList.add('particle');
                    
                    const size = Math.random() * 35 + 10;
                    particle.style.width = `${size}px`;
                    particle.style.height = `${size}px`;
                    particle.style.left = `${Math.random() * 100}%`;
                    particle.style.animationDelay = `${Math.random() * 5}s`;
                    particle.style.animationDuration = `${Math.random() * 7 + 5}s`;
                    
                    section.appendChild(particle);
                }
            });
        }
        createParticles();

        // --- CODE SISTEM EFEK CONFETTI JATUH ---
        const canvas = document.getElementById('confettiCanvas');
        const ctx = canvas.getContext('2d');
        let pieces = [];
        const numberOfPieces = 90;
        const colors = ['#ff758f', '#ffb3c1', '#ffccd5', '#ffffff', '#fee440'];

        function resizeCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class ConfettiPiece {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height - canvas.height;
                this.size = Math.random() * 7 + 4;
                this.color = colors[Math.floor(Math.random() * colors.length)];
                this.speed = Math.random() * 2.5 + 1.5;
                this.rotation = Math.random() * 360;
                this.rotationSpeed = Math.random() * 2 - 1;
            }
            update() {
                this.y += this.speed;
                this.rotation += this.rotationSpeed;
                if (this.y > canvas.height) {
                    this.y = -20;
                    this.x = Math.random() * canvas.width;
                }
            }
            draw() {
                ctx.save();
                ctx.translate(this.x, this.y);
                ctx.rotate(this.rotation * Math.PI / 180);
                ctx.fillStyle = this.color;
                ctx.fillRect(-this.size / 2, -this.size / 2, this.size, this.size);
                ctx.restore();
            }
        }

        for (let i = 0; i < numberOfPieces; i++) {
            pieces.push(new ConfettiPiece());
        }

        function animateConfetti() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            pieces.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animateConfetti);
        }
        animateConfetti();
    </script>
</body>
</html>